# Copy to .env and fill in. Never commit .env.

# Flask
SECRET_KEY=change-me-to-a-long-random-string

# When set in production, /check requires ?token=... or X-Cron-Token (GitHub cron)
# or a valid ui_token on "Check Now" links. Leave unset locally for open /check.
# CHECK_CRON_SECRET=

# SQLite: default is price_tracker.db next to the app. On Railway with a volume at /data:
# DB_PATH=/data/price_tracker.db
# DB_PATH=

# Periodic in-process APScheduler interval (hours). Use a large value (e.g. 999) if
# GitHub Actions is the only scheduler you want.
CHECK_INTERVAL_HOURS=6

# PORT=5000

DISCORD_WEBHOOK_URL=
GMAIL_USER=
GMAIL_APP_PASSWORD=
ALERT_EMAIL=

ENABLE_STARTUP_BACKFILL=1
FLASK_DEBUG=0

HF_TOKEN=
MAX_RESULTS_PER_SOURCE=50
REQUIRE_DISCOUNT=true
